# ============================================================
# NIS2 Plataforma PT — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to git.
# ============================================================

# --- Server ---
NODE_ENV=development
PORT=3000

# --- Database ---
DATABASE_URL=mysql://nis2user:CHANGE_ME@localhost:3306/nis2db

# --- Redis (rate limiting + cache) ---
REDIS_URL=redis://localhost:6379

# --- Auth ---
JWT_SECRET=CHANGE_ME_min_32_chars_random_string
COOKIE_SECRET=CHANGE_ME_min_32_chars_random_string

# --- OAuth (existing) ---
OAUTH_SERVER_URL=
OWNER_OPEN_ID=
VITE_APP_ID=

# --- Shodan API (scanner) ---
# Free InternetDB is used when this is empty.
# Get a key at https://account.shodan.io
SHODAN_API_KEY=

# --- Censys API (TLS analysis) ---
# Free tier: 250 queries/month
# Get credentials at https://search.censys.io/account
CENSYS_API_ID=
CENSYS_API_SECRET=

# --- Anthropic (AI questionnaire + remediation) ---
# https://console.anthropic.com
ANTHROPIC_API_KEY=
# Set to "false" to disable ALL AI calls without changing code (cost killswitch)
AI_ENABLED=true
# Optional model override (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=

# --- Stripe (billing) ---
# Use test keys during development
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_MSSP=price_...

# --- Resend (transactional email) ---
# https://resend.com
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@nis2pt.pt

# --- Hetzner Object Storage (certificates + course templates) ---
# Activate in May 2026 when templates are uploaded.
# Format: https://<bucket>.fsn1.your-objectstorage.com
STORAGE_ACCESS_KEY=
STORAGE_SECRET_KEY=
STORAGE_BUCKET=nis2pt-reports
STORAGE_REGION=eu-central-1
STORAGE_ENDPOINT=https://fsn1.your-objectstorage.com
STORAGE_PUBLIC_URL=https://nis2pt-reports.fsn1.your-objectstorage.com

# --- App public URL (used by Stripe redirects) ---
APP_URL=https://nis2pt.pt

# --- Dev helpers (NUNCA ligar em produção) ---
# Ignora TODAS as camadas de cache do scan (DB 24h + Redis Shodan/Censys/NVD).
# Cada scan com esta flag activa consome créditos de API reais.
# DEV_CACHE_DISABLED=true

# --- Internal ---
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=
